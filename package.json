{
  "name": "@koppajs/language-server",
  "version": "0.1.0",
  "description": "Language Server Protocol implementation for KoppaJS.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/koppajs/language-server"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "validate": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@koppajs/language-core": "file:../language-core",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "typescript": "^5.3.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
